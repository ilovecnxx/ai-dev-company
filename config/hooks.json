/**
 * ai-dev-company hooks 配置
 *
 * 这些 Hook 需要被合并到 ~/.claude/hooks/hooks.json 中
 * 运行 install.sh 脚本自动合并
 */

{
  "preToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${AI_DEV_COMPANY_ROOT:./}/scripts/hooks/pre-dev-workflow-check.js\""
        }
      ],
      "description": "检查开发工作流前置条件 (spec.md, plan.md)",
      "id": "pre:dev-workflow-check"
    }
  ],
  "postToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${AI_DEV_COMPANY_ROOT:./}/scripts/hooks/post-dev-quality-report.js\""
        }
      ],
      "description": "收集编辑文件并检查代码质量",
      "id": "post:dev-quality-report"
    }
  ],
  "stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${AI_DEV_COMPANY_ROOT:./}/scripts/hooks/stop-final-verdict.js\""
        }
      ],
      "description": "生成最终交付判定报告",
      "id": "stop:final-verdict"
    }
  ]
}