{
  "devWorkflow": {
    "blockedCommands": [
      "npm run build",
      "pnpm build",
      "yarn build",
      "npm run test",
      "pnpm test",
      "yarn test"
    ],
    "requiredFiles": [
      ".omc/autopilot/spec.md",
      ".omc/plans/autopilot-impl.md"
    ]
  },
  "qualityGates": {
    "maxConsoleLogs": 3,
    "maxTodos": 10,
    "maxEmptyCatch": 2,
    "allowDebuggers": false
  },
  "autopilot": {
    "maxQaCycles": 5,
    "maxValidationRounds": 3,
    "pauseAfterExpansion": false,
    "pauseAfterPlanning": false,
    "skipQa": false,
    "skipValidation": false
  },
  "agents": {
    "executor": {
      "model": "claude-sonnet-4-6",
      "level": 2
    },
    "architect": {
      "model": "claude-opus-4-6"
    },
    "critic": {
      "model": "claude-opus-4-6",
      "level": 3
    }
  }
}